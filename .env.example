# 環境変数の雛形。実際の値は git 管理外の .env にのみ置く（このファイルには値を書かないこと）。
#
# DB 系は手で埋めず、Vercel の Neon 統合から取得する：
#   pnpm dlx vercel link            # 初回のみ：ローカルを Vercel プロジェクトに紐付け
#   pnpm dlx vercel env pull .env   # Vercel の環境変数を .env へ書き出す（互換用の変数も一緒に入る）
# AUTH_ 系は各サービスで発行し、.env に手動で追記する。

# --- DB（vercel env pull で自動取得）---

# pooled（-pooler 付き）：アプリの通常クエリ用
DATABASE_URL=

# direct（-pooler なし）：マイグレーション用
DATABASE_URL_UNPOOLED=

# --- 認証（手動で追記）---

# Google OAuth（Google Cloud Console で発行）
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# auth.js のセッション暗号化キー（`npx auth secret` などで生成）
AUTH_SECRET=
