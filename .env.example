# .env は git 管理外。ここには実際の値を書かないこと。
# DB 系の値は手動コピペしない（Vercel の Neon 統合が自動注入）。
# ローカル開発では `vercel link` の後に `vercel env pull .env` で取得する。

# Neon の接続文字列（Vercel の Neon 統合で自動注入）
# pooled 接続（通常アプリ実行用）
DATABASE_URL=
# direct 接続（マイグレーション等で使用）
DATABASE_URL_UNPOOLED=

# Google OAuth（Google Cloud Console で発行）
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# auth.js のセッション暗号化キー（`npx auth secret` などで生成）
AUTH_SECRET=
